# =============================================================================
# Meowbox Environment Configuration
# Скопируй в .env и заполни свои значения (install.sh делает это автоматически).
# =============================================================================

# --- Panel ---
NODE_ENV=production
PANEL_DOMAIN=panel.example.com

# --- Ports ---
# API_PORT    — NestJS backend (internal, слушает 127.0.0.1)
# WEB_PORT    — Nuxt frontend (internal, слушает 127.0.0.1)
# PANEL_PORT  — публичный порт nginx reverse-proxy
# При смене портов регенерируй nginx-конфиг (повторный запуск install.sh обновит его автоматически).
API_PORT=11860
API_HOST=127.0.0.1
WEB_PORT=11861
PANEL_PORT=11862

# --- Database (SQLite — файл на диске, никакого PG/Redis) ---
# КРИТИЧНО: путь должен быть АБСОЛЮТНЫМ. Prisma резолвит относительный
# путь от api/prisma/, и в release-раскладке он уезжает внутрь releases/<v>/.
# release: file:/opt/meowbox/state/data/meowbox.db
# legacy:  file:/opt/meowbox/data/meowbox.db
DATABASE_URL=file:/opt/meowbox/state/data/meowbox.db

# --- JWT ---
JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Agent ---
AGENT_SECRET=CHANGE_ME_RANDOM_64_CHARS

# --- Nuxt ↔ API: Basic Auth internal token ---
# Обязан быть ЗАДАН и отличаться от AGENT_SECRET. Используется Nuxt middleware
# для проверки учётных данных Basic-Auth через API. Fallback на AGENT_SECRET
# больше не поддерживается.
INTERNAL_TOKEN=CHANGE_ME_RANDOM_64_CHARS

# --- Webhooks (HMAC) ---
WEBHOOK_SECRET=CHANGE_ME_RANDOM_64_CHARS

# --- Server-to-server proxy (для мульти-сервер миграций) ---
# Если задан, Api принимает X-Proxy-Token как альтернативу JWT (только от
# доверенных серверов). Невалидный токен отбивается 401 (ранее — fail-open).
# PROXY_TOKEN=CHANGE_ME_RANDOM_64_CHARS

# --- Trusted reverse-proxies (comma-separated IPs) ---
# Если API стоит за nginx/CF на этом же хосте, перечисли IP проксей,
# чтобы auth-контроллер доверял X-Forwarded-For только от них. Пусто —
# XFF игнорируется полностью (защита от подделки IP при brute-force).
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# --- Auth brute-force limits (per 15-min окна) ---
# AUTH_MAX_LOGIN_ATTEMPTS=10      # per-IP
# AUTH_MAX_USERNAME_ATTEMPTS=20   # per-username (защита от distributed spray)
# AUTH_LOGIN_ALERT_THRESHOLD=5    # уведомление админу после N неудач
# AUTH_REFRESH_TTL_SECONDS=604800 # 7 дней
# AUTH_REFRESH_GRACE_MS=15000     # grace-период для конкурентного refresh

# --- API: глобальные rate-limit'ы (ThrottlerModule) ---
# RATELIMIT_SHORT_TTL_MS=1000     RATELIMIT_SHORT_LIMIT=10
# RATELIMIT_MEDIUM_TTL_MS=10000   RATELIMIT_MEDIUM_LIMIT=50
# RATELIMIT_LONG_TTL_MS=60000     RATELIMIT_LONG_LIMIT=200

# --- AI assistant (Claude) ---
# Permission mode для claude CLI: default | acceptEdits | plan | bypassPermissions
# На проде рекомендуется acceptEdits, чтобы AI не мог запускать произвольные
# bash-команды от имени root без подтверждения.
# AI_PERMISSION_MODE=bypassPermissions
# AI_DEFAULT_CWD=/opt/meowbox

# --- Migration ---
# Лимит скачивания при import-pull (bytes). Default 20 GiB.
# MIGRATION_MAX_IMPORT_SIZE_BYTES=21474836480

# --- MODX versions fetching ---
# URL GitHub-API для списка тегов MODX. Для корпоративных зеркал / Gitea
# (внутренний git без outbound access) перекинь на свой endpoint.
# MODX_TAGS_URL=https://api.github.com/repos/modxcms/revolution/tags?per_page=100
# Анонимный GitHub API имеет лимит 60 req/hour на IP. С токеном — 5000/hour.
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxxx

# --- Multi-server provisioning ---
# Git URL, который используется при провижнинге дочернего сервера через SSH.
# По умолчанию — публичный репозиторий Meowbox.
# MEOWBOX_GIT_URL=https://github.com/gvozdb/meowbox.git
# Путь, куда заливается install.sh перед запуском. Значение по умолчанию подходит.
# MEOWBOX_INSTALL_SCRIPT_PATH=/tmp/meowbox-install.sh

# --- Agent: внешние хосты бэкап-хранилищ ---
# Можно направить на зеркало/прокси (например, корпоративный S3-прокси).
# YANDEX_DISK_API_HOST=cloud-api.yandex.net
# CLOUD_MAILRU_WEBDAV_HOST=webdav.cloud.mail.ru
# BACKUP_REMOTE_ROOT=/meowbox-backups
# BACKUP_HTTP_UPLOAD_MS=1800000
# BACKUP_HTTP_API_MS=30000

# --- Agent: лимиты терминала и файлов ---
# TERMINAL_MAX_SESSIONS=5
# TERMINAL_SESSION_TIMEOUT_MS=1800000
# TERMINAL_CLEANUP_INTERVAL_MS=60000
# FILES_MAX_READ_SIZE_BYTES=2097152

# --- Agent: CommandExecutor ---
# COMMAND_DEFAULT_TIMEOUT_MS=60000
# COMMAND_MAX_TIMEOUT_MS=1800000
# COMMAND_MAX_BUFFER_BYTES=10485760

# --- Agent: composer lookup ---
# Порядок поиска composer при вызове из инсталлера/деплоя.
# COMPOSER_PATHS=/usr/local/bin/composer,/usr/bin/composer

# --- Sites ---
SITES_BASE_PATH=/var/www
# Доп. префиксы, под которыми агенту разрешено удалять файлы сайтов
# (по-умолчанию SITES_BASE_PATH + /home — большинству этого хватает).
# ALLOWED_SITE_ROOT_PREFIXES=/var/www,/home,/srv/sites

# --- Backups ---
BACKUP_LOCAL_PATH=/var/backups/meowbox

# --- Agent: пути к системным конфигам (опционально, если сервер отличается) ---
# NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
# NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
# NGINX_GLOBAL_CONF=/etc/nginx/nginx.conf
# PHP_FPM_CONFIG_DIR=/etc/php
# PHP_FPM_SOCKET_DIR=/var/run/php
# PHP_LOG_DIR=/var/log/php
# DEFAULT_PHP_VERSION=8.2
# LETSENCRYPT_LIVE_DIR=/etc/letsencrypt/live
# CUSTOM_SSL_DIR=/etc/ssl/meowbox
# DB_EXPORTS_DIR=/var/meowbox/exports
# BACKUP_TEMP_PATH=/tmp/meowbox-backup
# MEOWBOX_BASE_DIR=/opt/meowbox        # корень monorepo для self-update
# SUPPORTED_PHP_VERSIONS=8.4,8.3,8.2,8.1,8.0,7.4  # comma-list для getVersions/UI

# --- Agent: лимиты очереди событий при временном дисконнекте API ---
# PENDING_EVENT_TTL_MS=300000       # TTL pending-события (5 мин)
# PENDING_EVENT_MAX_QUEUE=100       # размер очереди

# --- API: CORS/WebSocket ---
# Доп. origin'ы для WebSocket (comma-separated) — обычно не нужны.
# WS_EXTRA_ORIGINS=https://dev.panel.example.com

# --- API: лимиты на сессии терминала/tail для 1 браузерного клиента ---
# MAX_TERMINALS_PER_CLIENT=5
# MAX_TAILS_PER_CLIENT=10

# --- API: backup exports (download/STREAM/S3_PRESIGNED) ---
# BACKUP_EXPORT_MIN_TTL_HOURS=1
# BACKUP_EXPORT_MAX_TTL_HOURS=720           # 30 дней
# BACKUP_EXPORT_DEFAULT_TTL_HOURS=7
# BACKUP_EXPORT_MAX_CONCURRENT_STREAM=2     # лимит одновременных STREAM-сессий per-user
# BACKUP_EXPORT_RETENTION_DAYS=7            # сколько хранить EXPIRED-записи в БД
# BACKUP_EXPORT_CLEANUP_BATCH=200           # размер batch'а в cron-cleanup
# BACKUP_EXPORT_DOWNLOAD_TOKEN_TTL_SEC=600  # TTL токена в URL (короткий → меньше окно утечки)

# --- S3 defaults (используются API + agent для restic-репозиториев) ---
# S3_DEFAULT_REGION=us-east-1
# S3_DEFAULT_ENDPOINT=https://s3.amazonaws.com
# BACKUP_S3_PREFIX=meowbox

# --- Agent: streaming multipart upload в S3 (restic dump-to-s3) ---
# BACKUP_S3_PART_SIZE_BYTES=8388608   # 8 MiB
# BACKUP_S3_QUEUE_SIZE=4              # 4 параллельных части (RAM peak ≈ part × queue)
# BACKUP_S3_HEARTBEAT_MS=30000        # интервал диагностических логов
# BACKUP_S3_FALLBACK_MAX_BYTES=1073741824  # 1 GiB предохранитель fallback-ветки

# --- Agent: restic operations timeouts ---
# RESTIC_CHECK_TIMEOUT_MS=3600000     # restic check (read-data может быть долгим)
# RESTIC_LS_TIMEOUT_MS=600000         # restic ls --recursive

# --- API: scheduler alert thresholds ---
# ALERT_CPU_THRESHOLD=90              # CPU% при котором шлём notification
# ALERT_MEM_THRESHOLD=95              # Memory%
# ALERT_DISK_THRESHOLD=80             # Disk% — high (Yellow)
# ALERT_DISK_CRITICAL_THRESHOLD=90    # Disk% — almost full (Red)
# ALERT_COOLDOWN_MS=1800000           # 30 мин между повторными alert'ами

# --- API: scheduler watchdog/retention ---
# WATCHDOG_BACKUP_TIMEOUT_MS=14400000 # 4 часа — после этого «висящий» backup помечается ERROR
# WATCHDOG_DEPLOY_TIMEOUT_MS=3600000  # 1 час — для deploy
# HEALTH_PING_RETENTION_DAYS=7
# DISK_SNAPSHOT_RETENTION_DAYS=90
# MONITORING_RETENTION_DAYS=30        # metrics_snapshots cleanup

# --- API: migration TTL/poll ---
# MIGRATION_DOWNLOAD_TOKEN_TTL_MS=3600000
# MIGRATION_PULL_STATE_TTL_MS=600000
# MIGRATION_AGENT_POLL_INTERVAL_MS=5000

# --- Web: timeouts на запросы к internal-API ---
# INTERNAL_AUTH_TIMEOUT_MS=2000        # GET /api/internal/basic-auth
# INTERNAL_AUTH_VERIFY_TIMEOUT_MS=3000 # POST /api/internal/basic-auth/verify
# INTERNAL_AUTH_CACHE_TTL_MS=30000
# INTERNAL_AUTH_NEG_CACHE_TTL_MS=5000

# --- DNS module (encryption key for provider credentials) ---
# По умолчанию ключ автогенерится в `data/.dns-key` при первом старте API
# (perms 600). Никаких ручных действий не требуется.
#
# Опциональный override: 32-байтный ключ AES-256-GCM (base64) — если хочешь
# подсунуть ключ из секрет-менеджера / vault и не хранить его в файле:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# При смене ключа все ранее зашифрованные провайдеры станут нечитаемы — нужно
# удалить и пересоздать DnsProviderAccount-записи.
# DNS_CREDENTIAL_KEY=
