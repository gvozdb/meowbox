// =============================================================================
// Auth (бывший Redis — теперь SQLite)
// =============================================================================

/// Blacklist refresh-токенов (замена Redis `bl:{jti}`).
/// `expiresAt` — момент, после которого запись можно удалять (cron-чистка).
model TokenBlacklist {
  jti       String   @id
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("token_blacklist")
}

/// Счётчик неудачных попыток логина по IP (замена Redis `login_attempts:{ip}`).
/// TTL 15 минут: при `expiresAt < now()` запись считается устаревшей.
model LoginAttempt {
  ip        String   @id
  count     Int      @default(0)
  expiresAt DateTime @map("expires_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("login_attempts")
}

/// Метаданные активных refresh-токенов для IP-binding и отзыва (замена Redis `rt:{jti}` + `sessions:{userId}`).
model Session {
  jti       String   @id
  userId    String   @map("user_id")
  ip        String
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Универсальный KV-стор для настроек панели (General tab в /settings).
/// Значение — JSON-строка, парсится на чтении.
model PanelSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("panel_settings")
}

/// Сингл-стоп конфиг Basic Auth (защита входа в панель через HTTP Basic).
/// В таблице всегда не более одной записи (id = '_').
model BasicAuthConfig {
  id           String   @id @default("_")
  enabled      Boolean  @default(false)
  username     String   @default("")
  passwordHash String   @default("") @map("password_hash")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("basic_auth_config")
}

// =============================================================================
// DNS — управление DNS-записями через API внешних провайдеров.
// Креды провайдеров шифруются AES-256-GCM (master key из ENV DNS_CREDENTIAL_KEY).
// =============================================================================

/// Подключённый аккаунт DNS-провайдера (Cloudflare / Yandex Cloud / VK Cloud / Yandex 360).
/// `credentialsEnc` — base64(iv|tag|ciphertext) JSON-объекта со специфичными
/// для провайдера секретами (apiToken / serviceAccountKey / appCredential / oauthToken...).
model DnsProviderAccount {
  id             String    @id @default(uuid())
  type           String // CLOUDFLARE | YANDEX_CLOUD | VK_CLOUD | YANDEX_360
  label          String
  credentialsEnc String    @map("credentials_enc")
  // Yandex folderId / VK projectId / CF account-scope (опционально). Хранится
  // отдельно от credentialsEnc, чтобы UI мог показывать его без дешифровки.
  scopeId        String?   @map("scope_id")
  // Override базового URL DNS API (нужно для VK Cloud: их URL может меняться).
  apiBaseUrl     String?   @map("api_base_url")
  status         String    @default("ACTIVE") // ACTIVE | ERROR | UNAUTHORIZED
  lastError      String?   @map("last_error")
  lastSyncAt     DateTime? @map("last_sync_at")
  zonesCount     Int       @default(0) @map("zones_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  zones DnsZone[]

  @@map("dns_provider_accounts")
}

/// DNS-зона (домен) у внешнего провайдера. Зеркало стороннего ресурса:
/// `externalId` — id зоны у провайдера. Уникальна в рамках одного аккаунта.
model DnsZone {
  id              String    @id @default(uuid())
  accountId       String    @map("account_id")
  externalId      String    @map("external_id")
  domain          String // example.com (apex, без trailing dot)
  status          String    @default("ACTIVE")
  nameservers     String? // JSON array of NS hosts
  recordsCount    Int       @default(0) @map("records_count")
  recordsCachedAt DateTime? @map("records_cached_at")
  // Опциональная связь с сайтом панельки. SetNull при удалении сайта, чтобы
  // зону не потерять (она всё ещё существует у провайдера).
  linkedSiteId    String?   @map("linked_site_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  account    DnsProviderAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  linkedSite Site?              @relation(fields: [linkedSiteId], references: [id], onDelete: SetNull)
  records    DnsRecord[]

  @@unique([accountId, externalId])
  @@index([domain])
  @@map("dns_zones")
}

/// Кеш DNS-записей зоны. Истина — у провайдера; cache обновляется при refresh
/// и при mutation. Никогда не служит источником при несоответствии — UI всегда
/// может вызвать refresh, чтобы перезалить из upstream.
model DnsRecord {
  id         String   @id @default(uuid())
  zoneId     String   @map("zone_id")
  externalId String   @map("external_id")
  type       String // A | AAAA | CNAME | MX | TXT | NS | SRV | CAA
  // Относительное имя ("@" для apex, "www" и т.п.). Без trailing dot.
  name       String
  // Значение. Для multi-value (например VK/Yandex recordset) — JSON-массив.
  content    String
  ttl        Int
  priority   Int?
  // Cloudflare-only: orange-cloud (proxy через CF). null для остальных провайдеров.
  proxied    Boolean?
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  zone DnsZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, externalId])
  @@index([zoneId, type, name])
  @@map("dns_records")
}

// -----------------------------------------------------------------------------
// System migrations
// -----------------------------------------------------------------------------

/// Журнал применённых системных миграций.
/// Применяется runner'ом `node current/migrations/runner.js up` после `prisma migrate deploy`
/// при выполнении `make update`. Каждый файл в `migrations/system/<id>.{ts,js}` исполняется
/// один раз, дубль регистрируется по уникальному `id`. `checksum` — sha256 файла на момент
/// применения; если задним числом изменили — runner покажет warning.
model SystemMigration {
  id         String   @id // 2026-04-29-001-rename-public-to-www
  appliedAt  DateTime @default(now()) @map("applied_at")
  durationMs Int      @map("duration_ms")
  checksum   String // sha256 содержимого файла миграции
  ok         Boolean  @default(true)
  errorLog   String?  @map("error_log")

  @@map("system_migrations")
}

/// Текущее состояние процесса обновления панели (`make update` / UI button).
/// Один синглтон-ряд (id="current"). Используется как advisory lock —
/// если status=running и pid жив, второй запуск отклоняется.
/// История прошлых обновлений — в `panel_update_history`.
model PanelUpdateState {
  id            String    @id @default("current") // всегда "current"
  status        String    @default("idle") // idle | running | succeeded | failed | rolled_back
  fromVersion   String?   @map("from_version")
  toVersion     String?   @map("to_version")
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  pid           Int? // pid running update.sh — для проверки живости
  currentStage  String?   @map("current_stage") // preflight|snapshot|download|verify|migrate|build|switch|reload|healthcheck
  errorMessage  String?   @map("error_message")
  logTail       String?   @map("log_tail") // последние 16 KB stdout/stderr

  @@map("panel_update_state")
}

model PanelUpdateHistory {
  id           String   @id @default(uuid())
  fromVersion  String?  @map("from_version")
  toVersion    String   @map("to_version")
  status       String // succeeded | failed | rolled_back
  startedAt    DateTime @map("started_at")
  finishedAt   DateTime @map("finished_at")
  durationMs   Int      @map("duration_ms")
  triggeredBy  String?  @map("triggered_by") // userId | "cli" | "cron"
  errorMessage String?  @map("error_message")

  @@index([startedAt])
  @@map("panel_update_history")
}

// =============================================================================
// System cron jobs — задачи в crontab пользователя `root`. Управление
// аналогично per-site CronJob, но scope = SYSTEM (вне привязки к Site).
// Используется для общесистемных задач (дисковые проверки, бэкапы хоста и т.п.)
// и для импорта root-крона при миграции с hostpanel.
// =============================================================================

model SystemCronJob {
  id           String    @id @default(uuid())
  name         String
  schedule     String                // cron expression: "* * * * *"
  command      String
  status       String    @default("ACTIVE") // ACTIVE | DISABLED
  // Источник записи: MANUAL — оператор создал из UI; IMPORTED_HOSTPANEL —
  // строка пришла из hostpanel-миграции (отображается с пометкой в UI).
  source       String    @default("MANUAL")
  // Опциональный комментарий (одной строкой) — отображается под именем.
  comment      String?
  lastOutput   String?   @map("last_output")
  lastRunAt    DateTime? @map("last_run_at")
  lastExitCode Int?      @map("last_exit_code")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("system_cron_jobs")
}

// =============================================================================
// Hostpanel migration — перенос сайтов со старой "hostPanel" (компонент MODX)
// на slave-сервер meowbox. Двухуровневая модель:
//   - HostpanelMigration: один запуск (источник + целевой slave + общий статус)
//   - HostpanelMigrationItem: один сайт внутри запуска (план + статус + лог)
//
// Безопасность кредов: SSH/MySQL пароли источника шифруются AES-256-GCM
// ключом MIGRATION_SECRET (env, генерится system-миграцией). В UI пароли
// никогда не отображаются после ввода.
//
// Транзакционная семантика: каждый item — независимая псевдо-транзакция.
// На сбое — cleanup только артефактов с migrationId === currentId.
// =============================================================================

model HostpanelMigration {
  id          String   @id @default(uuid())
  // PLANNED — создан, ещё не запускался
  // DISCOVERING — идёт пробинг источника
  // READY — discovery закончен, оператор редактирует план
  // RUNNING — выполняется
  // DONE — все sайты успешно
  // FAILED — все упали или фатальная ошибка
  // PARTIAL — часть успешно, часть упала
  // CANCELLED — отменён оператором
  status      String   @default("PLANNED")
  // JSON: { host, port, sshUser, sshPassEnc, mysqlHost, mysqlPort, mysqlUser,
  //         mysqlPassEnc, hostpanelDb, hostpanelTablePrefix }
  // Пароли в *Enc — base64(iv|tag|ciphertext) под MIGRATION_SECRET.
  // Миграция всегда локальна слейву, на котором живёт эта запись (master
  // проксирует REST-запросы по `/proxy/{serverId}/...` в выбранный slave).
  source      String
  // JSON: snapshot источника на момент discover (sites[], manticore, php-versions, ...)
  // null до завершения discovery.
  discovery   String?
  totalSites  Int      @default(0) @map("total_sites")
  doneSites   Int      @default(0) @map("done_sites")
  failedSites Int      @default(0) @map("failed_sites")
  // Append-only лог стрима. Хранится последние 500 KB.
  log         String   @default("")
  errorMessage String? @map("error_message")
  createdAt   DateTime @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdBy   String   @map("created_by") // User.id

  items HostpanelMigrationItem[]

  @@index([status])
  @@index([createdAt])
  @@map("hostpanel_migrations")
}

model HostpanelMigrationItem {
  id              String    @id @default(uuid())
  migrationId     String    @map("migration_id")
  // hostpanel sites.id (modx_host_hostpanel_sites.id) — на источнике
  sourceSiteId    Int       @map("source_site_id")
  // JSON: исходная строка (sftp_pass, mysql_pass извлечены отдельно в migration.source)
  sourceData      String    @map("source_data")
  // JSON: PlanItem (см. spec §6.3) — финальный план миграции этого сайта
  plan            String
  // PLANNED|RUNNING|DONE|FAILED|SKIPPED|CONFLICT
  status          String    @default("PLANNED")
  // FK на Site после успеха (null до DONE или при FAILED/SKIPPED)
  newSiteId       String?   @map("new_site_id")
  errorMsg        String?   @map("error_msg")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  // 0..100 — текущий прогресс (для rsync/dump — реальный, иначе round-up по стейджам)
  progressPercent Int       @default(0) @map("progress_percent")
  // Имя текущего стейджа: pre-flight | create-user | rsync-files | db-create | ...
  currentStage    String?   @map("current_stage")
  // Последние 200 KB лога этого item (rsync output, mysqldump errors etc.)
  log             String    @default("")

  migration HostpanelMigration @relation(fields: [migrationId], references: [id], onDelete: Cascade)

  @@index([migrationId])
  @@index([status])
  @@map("hostpanel_migration_items")
}

// Сохранённые пресеты подключения к источникам hostPanel. Оператор не должен
// каждый раз вбивать SSH/MySQL креды — выбрал из списка → форма
// заполнилась → жмём «Сканировать». Пароли шифруются тем же
// MIGRATION_SECRET'ом, что и в HostpanelMigration.source. Ни в каком виде
// в API наружу не отдаются — для запуска discovery фронт шлёт sourceId,
// бэкенд внутри подставляет креды.
model HostpanelMigrationSource {
  id                   String    @id @default(uuid())
  // Удобочитаемое имя в UI («vm120 prod», «backup-server» и т.п.).
  name                 String
  host                 String
  port                 Int       @default(22)
  sshUser              String    @map("ssh_user")
  sshPassEnc           String    @map("ssh_pass_enc") // base64 AES-256-GCM
  mysqlHost            String    @map("mysql_host")
  mysqlPort            Int       @default(3306) @map("mysql_port")
  mysqlUser            String    @map("mysql_user")
  mysqlPassEnc         String    @map("mysql_pass_enc")
  hostpanelDb          String    @map("hostpanel_db")
  hostpanelTablePrefix String    @map("hostpanel_table_prefix")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  // Когда последний раз через этот пресет запускали discovery — сортируем
  // по нему в UI, чтобы недавно использованные были сверху.
  lastUsedAt           DateTime? @map("last_used_at")
  createdBy            String    @map("created_by") // User.id

  // Уникальная пара host+sshUser+mysqlUser защищает от дублей при невнимательном
  // повторном сохранении того же сервера.
  @@unique([host, sshUser, mysqlUser])
  @@index([lastUsedAt])
  @@map("hostpanel_migration_sources")
}

// =============================================================================
// VPN Management
// См. docs/specs/2026-05-09-vpn-management.md
//
// Архитектурные пометки:
//   - Один сервис = одна VPN-инсталляция конкретного протокола на этом сервере
//     (на одном сервере может быть несколько сервисов разных протоколов и
//     разных портов одновременно).
//   - VpnUser — глобальная сущность панели; имеет subToken (per-user URL
//     подписки) и может состоять в N сервисах через VpnUserCreds (M:N).
//   - configBlob/credsBlob — base64 AES-256-GCM (vpn-cipher.ts).
// =============================================================================

model VpnService {
  id        String   @id @default(uuid())
  /// Произвольное имя сервиса для UI ("Reality Main", "Резервный WG", ...).
  /// Если null — UI рендерит "<protocol>:<port>".
  label     String?
  /// VpnProtocol enum: VLESS_REALITY | AMNEZIA_WG.
  protocol  String
  port      Int
  /// VpnServiceStatus enum: RUNNING | STOPPED | ERROR | DEPLOYING.
  status    String   @default("DEPLOYING")
  /// Сообщение об ошибке для статуса ERROR (показывается в UI).
  errorMessage     String?  @map("error_message")
  /// Зашифрованный JSON: VpnRealityServiceConfig | VpnAmneziaWgServiceConfig.
  /// Включает приватный ключ сервера + детали обфускации.
  configBlob       String   @map("config_blob")
  /// Только для VLESS_REALITY: SNI-маска отдельным полем для индексации
  /// и быстрого UI-рендера без дешифровки.
  sniMask          String?  @map("sni_mask")
  /// Результат последней автоматической проверки SNI (cron раз в 6 ч).
  sniLastCheckOk   Boolean? @map("sni_last_check_ok")
  sniLastCheckedAt DateTime? @map("sni_last_checked_at")
  sniLastError     String?  @map("sni_last_error")
  /// Имя egress-интерфейса для AmneziaWG (eth0/ens3) — кешируем чтобы при
  /// рестарте/обновлении не считать заново.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userCreds VpnUserCreds[]

  @@unique([protocol, port])
  @@index([protocol])
  @@map("vpn_services")
}

model VpnUser {
  id        String   @id @default(uuid())
  /// Произвольное имя для UI и в комменте VLESS-URL/WG-конфига.
  /// Уникально per-panel (не per-service), так как юзер глобальный.
  name      String   @unique
  /// Random 32 bytes hex — токен для GET /api/vpn/sub/:token endpoint.
  /// Регенерируется по запросу (для отзыва доступа).
  subToken  String   @unique @map("sub_token")
  /// Глобальный enable/disable. Если false — все creds в свяках с сервисами
  /// удаляются из inbounds (xray) и peer'ов (wg) — но остаются в БД для
  /// возможного re-enable.
  enabled   Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creds     VpnUserCreds[]

  @@map("vpn_users")
}

/// Связка юзер-сервис: один юзер может быть в N сервисах одновременно
/// (например VLESS+Reality на 443/TCP и AmneziaWG на 51820/UDP).
/// При создании юзера в UI чек-боксами выбираем, в какие сервисы его положить.
model VpnUserCreds {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  serviceId String   @map("service_id")
  /// Зашифрованный JSON: VpnRealityUserCreds | VpnAmneziaWgUserCreds.
  credsBlob String   @map("creds_blob")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    VpnUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service VpnService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@map("vpn_user_creds")
}
