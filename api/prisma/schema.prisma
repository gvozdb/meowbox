generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Примечания по миграции с PostgreSQL на SQLite:
// - enum → String (значения валидируются в коде, см. src/common/enums.ts)
// - String[] → String (хранится как JSON-массив строк; парсится через
//   parseStringArray() в src/common/json-array.ts)
// - @db.Uuid / @db.VarChar(N) убраны — SQLite их не поддерживает
// - Json / BigInt / DateTime остаются нативными типами Prisma для SQLite
// =============================================================================

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("ADMIN") // UserRole
  totpEnabled  Boolean  @default(false) @map("totp_enabled")
  totpSecret   String?  @map("totp_secret")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sites                Site[]
  notificationSettings NotificationSetting[]
  auditLogs            AuditLog[]
  aiSessions           AiSession[]
  backupExports        BackupExport[]

  @@map("users")
}

model Site {
  id               String   @id @default(uuid())
  // `name` — системное имя (= имя Linux-юзера, имя БД, имя БД-юзера). Уникально.
  // Должно начинаться с буквы, [a-z0-9_-], max 32 символов.
  name             String   @unique
  // `displayName` — человекочитаемое название для списка сайтов.
  // Необязательное: если null/пусто — UI показывает `name`.
  displayName      String?  @map("display_name")
  domain           String   @unique
  aliases          String   @default("[]") // JSON string[]
  type             String // SiteType
  status           String   @default("STOPPED") // SiteStatus
  // Последнее сообщение об ошибке (для статуса ERROR). Пишется при провале
  // провижининга/деплоя, показывается в UI; очищается при успешном запуске.
  errorMessage     String?  @map("error_message")
  phpVersion       String?  @map("php_version")
  gitRepository    String?  @map("git_repository")
  deployBranch     String?  @map("deploy_branch")
  appPort          Int?     @map("app_port")
  envVars          String   @default("{}") @map("env_vars") // JSON object
  rootPath         String   @map("root_path")
  nginxConfigPath  String   @map("nginx_config_path")
  systemUser       String?  @map("site_user")
  /// AES-256-GCM, HKDF(master,'meowbox:ssh:v1'). См. spec master-key-unification.
  sshPasswordEnc   String?  @map("ssh_password_enc")
  cmsAdminUser     String?  @map("cms_admin_user")
  /// AES-256-GCM, HKDF(master,'meowbox:cms:v1').
  cmsAdminPasswordEnc String? @map("cms_admin_password_enc")
  managerPath      String?  @map("manager_path")
  connectorsPath   String?  @map("connectors_path")
  // Версия установленной CMS (для MODX: "2.8.8-pl", "3.1.2-pl" и т.п.).
  modxVersion      String?  @map("modx_version")
  // Кастомный фрагмент php-fpm пула — дописывается в конец pool-конфига при
  // генерации на агенте. Переживает смену phpVersion (переносится в новый пул).
  // null/пусто — никаких кастомных overrides.
  phpPoolCustom    String?  @map("php_pool_custom")
  // Модули CUSTOM-сайта (для MODX всегда true). PHP включён по наличию phpVersion.
  dbEnabled        Boolean  @default(false) @map("db_enabled")
  httpsRedirect    Boolean  @default(true) @map("https_redirect")
  // Относительный путь до web-root внутри rootPath (обычно "www", но можно "public_html" и т.п.).
  filesRelPath     String   @default("www") @map("files_rel_path")
  // -----------------------------------------------------------------------
  // Layered nginx settings — параметризуют шаблоны в meowbox/{siteName}/*.conf.
  // Перегенерируются при PUT /sites/:id/nginx/settings. null/0 → дефолты из
  // shared/nginx-defaults.ts.
  // -----------------------------------------------------------------------
  /// max body размер (значение в формате nginx: "32M", "100M", "1G"). Default "32M".
  nginxClientMaxBodySize String? @map("nginx_client_max_body_size")
  /// fastcgi_read_timeout (сек). Default 60.
  nginxFastcgiReadTimeout    Int? @map("nginx_fastcgi_read_timeout")
  /// fastcgi_send_timeout (сек). Default 60.
  nginxFastcgiSendTimeout    Int? @map("nginx_fastcgi_send_timeout")
  /// fastcgi_connect_timeout (сек). Default 60.
  nginxFastcgiConnectTimeout Int? @map("nginx_fastcgi_connect_timeout")
  /// fastcgi_buffer_size (KB). Default 32.
  nginxFastcgiBufferSizeKb   Int? @map("nginx_fastcgi_buffer_size_kb")
  /// fastcgi_buffers count (штук, размер каждого = nginxFastcgiBufferSizeKb / 2). Default 16.
  nginxFastcgiBufferCount    Int? @map("nginx_fastcgi_buffer_count")
  /// HTTP/2 включён (только при SSL). Default true.
  nginxHttp2     Boolean @default(true) @map("nginx_http2")
  /// Strict-Transport-Security header (max-age=63072000; includeSubDomains). Default false.
  nginxHsts      Boolean @default(false) @map("nginx_hsts")
  /// gzip компрессия. Default true.
  nginxGzip      Boolean @default(true) @map("nginx_gzip")
  /// Per-site rate limiting (nginx limit_req). Если null/false — директива не пишется.
  nginxRateLimitEnabled Boolean @default(true) @map("nginx_rate_limit_enabled")
  /// requests-per-second в zone-объявлении (limit_req_zone ... rate=Xr/s). Default 30.
  nginxRateLimitRps     Int?    @map("nginx_rate_limit_rps")
  /// burst для limit_req. Default 60.
  nginxRateLimitBurst   Int?    @map("nginx_rate_limit_burst")
  /// Кастомный конфиг — содержимое 95-custom.conf, инклюдится В ТЕЛО основного server-блока.
  /// Юзер редактирует через UI. Панель НЕ перезаписывает этот блок при операциях.
  /// При установке CMS (MODX) сюда автоматически дописываются её правила (try_files и т.п.) —
  /// пользователь дальше может править их под себя.
  nginxCustomConfig String? @map("nginx_custom_config")
  // Per-site дефолтные excludes для бэкапов (JSON string[]). Пустой массив или
  // null — fallback на глобальные дефолты из panel_settings.backup-defaults.
  backupExcludes        String?  @map("backup_excludes")
  // Per-site список таблиц БД, которые дампятся БЕЗ данных (только структура).
  // JSON string[]. null/[] — fallback на глобальные.
  backupExcludeTables   String?  @map("backup_exclude_tables")
  // Произвольный JSON для маркеров и meta-данных. Пример:
  //   { "migrationId": "<HostpanelMigration.id>", "importedFrom": "vm120", "originalUid": 1002 }
  // Используется hostpanel-миграцией для контракта cleanup'а: cleanup трогает
  // только сайты с metadata.migrationId === currentMigrationId.
  metadata              String?  // JSON object
  userId           String   @map("user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  databases      Database[]
  sslCertificate SslCertificate?
  deployLogs     DeployLog[]
  backupConfigs  BackupConfig[]
  backups        Backup[]
  cronJobs       CronJob[]
  diskSnapshots  SiteDiskSnapshot[]
  healthPings    HealthCheckPing[]
  dnsZones       DnsZone[]
  services       SiteService[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("sites")
}

// =============================================================================
// Сервисы (Manticore Search и др.) — внешние демоны, которыми сайты могут
// пользоваться. Двухуровневая модель:
//   - ServerService — установлен ли сервис на сервере (apt-пакет, systemd unit-template).
//   - SiteService   — активирован ли сервис для конкретного сайта (per-site instance).
// Per-site инстансы изолированы: свой data_dir, свой socket в /var/www/{site}/tmp/,
// systemd template `{service}@{siteName}.service`.
// =============================================================================

/// Серверный уровень сервиса: версия, статус установки на хост.
/// Один сервис = одна запись (`serviceKey` UNIQUE).
model ServerService {
  id          String    @id @default(uuid())
  serviceKey  String    @unique @map("service_key") // 'manticore', 'redis', ...
  installed   Boolean   @default(false)
  version     String?
  installedAt DateTime? @map("installed_at")
  lastError   String?   @map("last_error")
  config      String    @default("{}") // JSON, серверный конфиг сервиса
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("server_services")
}

/// Активация сервиса для конкретного сайта.
/// `status`: STOPPED — активирован но демон выключен; RUNNING — активен;
/// ERROR — последняя операция упала; STARTING — переходное состояние.
/// `config` хранит per-site overrides (например, memoryMaxMb) — пусто = дефолт.
model SiteService {
  id          String    @id @default(uuid())
  siteId      String    @map("site_id")
  serviceKey  String    @map("service_key")
  status      String    @default("STOPPED") // STARTING | RUNNING | STOPPED | ERROR
  config      String    @default("{}") // JSON: per-site overrides
  lastError   String?   @map("last_error")
  installedAt DateTime  @default(now()) @map("installed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, serviceKey])
  @@index([siteId])
  @@index([serviceKey])
  @@map("site_services")
}

model Database {
  id             String   @id @default(uuid())
  name           String   @unique
  type           String // DatabaseType
  dbUser         String   @map("db_user")
  dbPasswordHash String   @map("db_password_hash")
  // Симметрично-зашифрованный плейн-пароль (AES-256-GCM, base64).
  // Нужен, чтобы открывать БД во встроенном Adminer без ресета. Argon2-хэш —
  // односторонний, поэтому хранить плейн отдельно неизбежно. Шифровка через
  // тот же master-key, что и DNS-credentials (`credentials-cipher.ts`).
  // NULL для legacy-записей, созданных до этой колонки — у них Adminer
  // потребует ресет пароля.
  dbPasswordEnc  String?  @map("db_password_enc")
  siteId         String?  @map("site_id")
  sizeBytes      BigInt   @default(0) @map("size_bytes")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([siteId])
  @@map("databases")
}

// Именованное хранилище для бэкапов. Переиспользуется разными сайтами и
// обоими движками (TAR / RESTIC). `config` — JSON с настройками доступа
// (accessKey/bucket/endpoint/oauthToken/username/password и т.п., зависит
// от `type`). `resticPassword` — пароль репы Restic на этом хранилище;
// генерируется при создании, показывается юзеру один раз.
model StorageLocation {
  id              String   @id @default(uuid())
  name            String   @unique
  type            String   // BackupStorageType: LOCAL | S3 | YANDEX_DISK | CLOUD_MAIL_RU
  config          String   @default("{}") // JSON object (креды + опции)
  resticPassword  String?  @map("restic_password")
  // Поддерживает ли это хранилище Restic-движок (LOCAL и S3 — да; Y.Disk/Mail.ru — нет)
  resticEnabled   Boolean  @default(false) @map("restic_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  backups                    Backup[]
  backupConfigs              BackupConfig[]
  resticChecks               ResticCheck[]
  serverPathBackupConfigs    ServerPathBackupConfig[] @relation("ServerPathBackupConfigToStorageLocation")
  serverPathBackups          ServerPathBackup[]       @relation("ServerPathBackupToStorageLocation")
  panelDataBackupConfigs     PanelDataBackupConfig[]  @relation("PanelDataBackupConfigToStorageLocation")
  panelDataBackups           PanelDataBackup[]        @relation("PanelDataBackupToStorageLocation")

  @@map("storage_locations")
}

// История запусков `restic check` — проверка целостности Restic-репозитория.
// Репа = (siteName, storageLocation) — поэтому одна пара хранит свою историю.
// Пишется при ручном запуске из UI и при плановом запуске (scheduler).
model ResticCheck {
  id                String   @id @default(uuid())
  storageLocationId String   @map("storage_location_id")
  // Денормализованное имя сайта (репа именуется по нему).
  // Не FK на Site, чтобы история выжила, если сайт удалят.
  siteName          String   @map("site_name")
  siteId            String?  @map("site_id") // опциональная связь для быстрого join'а
  success           Boolean  @default(false)
  errorMessage      String?  @map("error_message")
  output            String?  // stdout restic'а, первые ~4KB
  readData          Boolean  @default(false) @map("read_data")
  readDataSubset    String?  @map("read_data_subset")
  durationMs        Int?     @map("duration_ms")
  // Причина запуска: manual | scheduled
  source            String   @default("manual")
  startedAt         DateTime @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")

  storageLocation StorageLocation @relation(fields: [storageLocationId], references: [id], onDelete: Cascade)

  @@index([storageLocationId, siteName])
  @@index([startedAt])
  @@map("restic_checks")
}

model BackupConfig {
  id                 String   @id @default(uuid())
  siteId             String   @map("site_id")
  type               String // BackupType
  // Движок: TAR (старый) / RESTIC (новый, по умолчанию для новых конфигов)
  engine             String   @default("TAR") // BackupEngine
  // Новая схема: список StorageLocation.id (JSON-массив). При автобэкапе
  // архив отправляется в каждое из хранилищ. Для ручного бэкапа выбирается одно.
  storageLocationIds String   @default("[]") @map("storage_location_ids") // JSON string[]
  // Legacy: storageType/storageConfig оставлены nullable для обратной совместимости
  // со старыми записями (мигрируются в StorageLocation при первом редактировании).
  storageType        String?  @map("storage_type") // BackupStorageType
  storageConfig      String?  @map("storage_config") // JSON object
  schedule           String?
  retention          Int      @default(7) // TAR: кол-во бэкапов. Для Restic используются keep*
  // Retention для Restic (`restic forget --keep-*`)
  keepDaily          Int      @default(7) @map("keep_daily")
  keepWeekly         Int      @default(4) @map("keep_weekly")
  keepMonthly        Int      @default(6) @map("keep_monthly")
  keepYearly         Int      @default(1) @map("keep_yearly")
  excludePaths       String   @default("[]") @map("exclude_paths") // JSON string[]
  excludeTableData   String   @default("[]") @map("exclude_table_data") // JSON string[]
  keepLocalCopy      Boolean  @default(false) @map("keep_local_copy")
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  site             Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  backups          Backup[]
  storageLocations StorageLocation[]

  @@index([siteId])
  @@map("backup_configs")
}

// =============================================================================
// Server-path backups: бэкап произвольных директорий сервера (/etc, /opt, /root).
// Один путь = один config. См. docs/specs/2026-05-10-unified-backups.md.
// =============================================================================
model ServerPathBackupConfig {
  id                   String   @id @default(uuid())
  /// Имя конфига для UI и логов: "etc daily", "opt weekly", ...
  name                 String
  /// Абсолютный путь. Один путь на конфиг — если нужны разные расписания,
  /// создаёшь второй config с тем же path.
  path                 String
  /// Подтверждение, что юзер прочитал warning'и о пути из warnlist
  /// (`/var/log`, `/var/lib/mysql`, ...). Для аудита.
  warningAcknowledged  Boolean  @default(false) @map("warning_acknowledged")
  /// Движок: TAR (классический tar.gz) | RESTIC (дедупликация).
  engine               String   @default("RESTIC")
  /// Список StorageLocation.id (JSON-массив).
  storageLocationIds   String   @default("[]") @map("storage_location_ids")
  schedule             String?  // cron expression
  retention            Int      @default(7)
  keepDaily            Int      @default(7) @map("keep_daily")
  keepWeekly           Int      @default(4) @map("keep_weekly")
  keepMonthly          Int      @default(6) @map("keep_monthly")
  keepYearly           Int      @default(1) @map("keep_yearly")
  /// Restic-exclude паттерны (относительно path).
  excludePaths         String   @default("[]") @map("exclude_paths")
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  backups              ServerPathBackup[]
  storageLocations     StorageLocation[]  @relation("ServerPathBackupConfigToStorageLocation")

  @@index([enabled])
  @@map("server_path_backup_configs")
}

model ServerPathBackup {
  id                String    @id @default(uuid())
  configId          String    @map("config_id")
  status            String    @default("PENDING") // BackupStatus
  engine            String    @default("RESTIC")
  storageLocationId String?   @map("storage_location_id")
  resticSnapshotId  String?   @map("restic_snapshot_id")
  filePath          String    @default("") @map("file_path")
  sizeBytes         BigInt?   @map("size_bytes")
  progress          Int       @default(0)
  errorMessage      String?   @map("error_message")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  config            ServerPathBackupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  storageLocation   StorageLocation?       @relation("ServerPathBackupToStorageLocation", fields: [storageLocationId], references: [id], onDelete: SetNull)

  @@index([configId])
  @@index([status])
  @@map("server_path_backups")
}

// =============================================================================
// Panel-data backups: жёстко зашитый набор путей для бэкапа данных самой панели.
// Путей юзер не выбирает — preset защищает от ошибки "забыл .master-key".
// =============================================================================
model PanelDataBackupConfig {
  id                   String   @id @default(uuid())
  name                 String
  engine               String   @default("RESTIC")
  storageLocationIds   String   @default("[]") @map("storage_location_ids")
  schedule             String?
  retention            Int      @default(7)
  keepDaily            Int      @default(24) @map("keep_daily")     // 24 hourly = day
  keepWeekly           Int      @default(7) @map("keep_weekly")     // 7 days
  keepMonthly          Int      @default(12) @map("keep_monthly")
  keepYearly           Int      @default(5) @map("keep_yearly")
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  backups              PanelDataBackup[]
  storageLocations     StorageLocation[] @relation("PanelDataBackupConfigToStorageLocation")

  @@index([enabled])
  @@map("panel_data_backup_configs")
}

model PanelDataBackup {
  id                String    @id @default(uuid())
  configId          String    @map("config_id")
  status            String    @default("PENDING")
  engine            String    @default("RESTIC")
  storageLocationId String?   @map("storage_location_id")
  resticSnapshotId  String?   @map("restic_snapshot_id")
  filePath          String    @default("") @map("file_path")
  sizeBytes         BigInt?   @map("size_bytes")
  progress          Int       @default(0)
  errorMessage      String?   @map("error_message")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  config            PanelDataBackupConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  storageLocation   StorageLocation?      @relation("PanelDataBackupToStorageLocation", fields: [storageLocationId], references: [id], onDelete: SetNull)

  @@index([configId])
  @@index([status])
  @@map("panel_data_backups")
}

model Backup {
  id                String    @id @default(uuid())
  siteId            String    @map("site_id")
  configId          String?   @map("config_id")
  type              String // BackupType
  status            String    @default("PENDING") // BackupStatus
  // Движок, которым сделан этот бэкап
  engine            String    @default("TAR") // BackupEngine
  // Для новых записей: привязка к StorageLocation (id)
  storageLocationId String?   @map("storage_location_id")
  // Для Restic: id снапшота в репе. Null для TAR.
  resticSnapshotId  String?   @map("restic_snapshot_id")
  // Legacy: для TAR это путь к архиву. Для Restic не используется.
  storageType       String?   @map("storage_type") // BackupStorageType (legacy, nullable)
  filePath          String    @default("") @map("file_path")
  sizeBytes         BigInt?   @map("size_bytes")
  progress          Int       @default(0)
  errorMessage      String?   @map("error_message")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  baseBackupId      String?   @map("base_backup_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  site            Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  config          BackupConfig?    @relation(fields: [configId], references: [id], onDelete: SetNull)
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  baseBackup      Backup?          @relation("DiffBase", fields: [baseBackupId], references: [id], onDelete: SetNull)
  differentials   Backup[]         @relation("DiffBase")
  exports         BackupExport[]

  @@index([siteId])
  @@index([status])
  @@map("backups")
}

// Экспорт бэкапа в виде скачиваемого архива.
// Два режима:
//   STREAM        — API спавнит restic dump --archive tar и стримит stdout прямо
//                   в HTTP response. Без диска, без сокетов. Single-host only.
//   S3_PRESIGNED  — агент делает restic dump → загружает tar в тот же bucket
//                   под exports/<id>.tar → API возвращает pre-signed URL.
//                   Подходит для S3-хранилищ; trafic качается напрямую из S3.
// expiresAt — время истечения. Cron каждый час смотрит истекшие, удаляет
// S3-объект и помечает запись EXPIRED. Для STREAM — просто чистится запись.
model BackupExport {
  id            String    @id @default(uuid())
  backupId      String    @map("backup_id")
  mode          String    @default("STREAM") // BackupExportMode: STREAM | S3_PRESIGNED
  status        String    @default("PENDING") // BackupExportStatus: PENDING | PROCESSING | READY | FAILED | EXPIRED
  // Для S3_PRESIGNED: ключ объекта в bucket (`exports/<uuid>.tar`).
  s3Key         String?   @map("s3_key")
  // URL для скачивания: либо API-роут (STREAM), либо pre-signed URL (S3).
  downloadUrl   String?   @map("download_url")
  // Когда истекает экспорт. Cron-cleaner смотрит на это поле.
  expiresAt     DateTime  @map("expires_at")
  sizeBytes     BigInt?   @map("size_bytes")
  errorMessage  String?   @map("error_message")
  // Юзер, инициировавший экспорт (для аудита и проверки прав на скачивание).
  createdByUserId String  @map("created_by_user_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  backup        Backup    @relation(fields: [backupId], references: [id], onDelete: Cascade)
  createdByUser User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([backupId])
  @@index([status])
  @@index([expiresAt])
  @@map("backup_exports")
}

model SslCertificate {
